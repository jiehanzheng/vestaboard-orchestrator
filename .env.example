# Copy to .env and fill in your values.

ORCHESTRATOR_INTERVAL_MINUTES=5

# Vestaboard Cloud Read/Write API.
VESTABOARD_MODE=cloud
VESTABOARD_TOKEN=
VESTABOARD_CLOUD_URL=https://cloud.vestaboard.com/

# For local Vestaboard mode instead of cloud:
# VESTABOARD_MODE=local
# VESTABOARD_LOCAL_API_KEY=
# VESTABOARD_LOCAL_URL=http://vestaboard.local:7000/local-api/message

# Codex quota plugin.
CODEX_QUOTA_SOURCE=app-server
CODEX_QUOTA_PRIORITY=normal
CODEX_QUOTA_ERROR_PRIORITY=low
CODEX_QUOTA_TIME_ZONE=America/Los_Angeles
CODEX_QUOTA_DEMO_PAUSE_MINUTES=5

# Host path mounted to /home/node/.codex so Codex auth persists in Docker.
# Defaults to ${HOME}/.codex when omitted.
# CODEX_HOST_DIR=/Users/you/.codex
