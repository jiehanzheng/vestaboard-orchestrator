{
  "name": "vestaboard-orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "pnpm build && node dist/src/index.js",
    "once": "pnpm build && node dist/src/index.js --once",
    "dry-run": "pnpm build && node dist/src/index.js --once --dry-run",
    "test": "pnpm build && node --test dist/test/*.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
}
